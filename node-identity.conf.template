# Copilot HQ — Node Identity Configuration
# Copy this file to node-identity.conf and edit for THIS machine.
# node-identity.conf is gitignored — it is NOT committed to git.
# Each machine in the fleet has its own local copy.
#
# Setup:
#   cp node-identity.conf.template node-identity.conf
#   # then edit NODE_ID, NODE_ROLE, etc. for this machine

# ---------------------------------------------------------------------------
# Node identity
# ---------------------------------------------------------------------------
NODE_ID=dev-laptop              # must match a row in dashboards/PROJECTS.md Node Registry
NODE_ROLE=worker                # worker | master
NODE_LABEL="My Dev Machine"

# ---------------------------------------------------------------------------
# Projects this node is responsible for (space-separated canonical keys).
# Must match the Project key column in dashboards/PROJECTS.md
# ---------------------------------------------------------------------------
NODE_PROJECTS="forseti-jobhunter-automation forseti-safety-application forseti-agent-tracker dungeoncrawler infrastructure"

# ---------------------------------------------------------------------------
# Default agent seat used when no per-project agent is specified.
# ---------------------------------------------------------------------------
NODE_DEFAULT_AGENT=dev-forseti

# ---------------------------------------------------------------------------
# Active agents on this node (space-separated).
# dev-sync-once.sh will ONLY claim commands addressed to these agents.
# Commands for other agents are skipped — they belong to other nodes.
# ---------------------------------------------------------------------------
NODE_ACTIVE_AGENTS="dev-forseti qa-forseti ba-forseti agent-explore-forseti agent-task-runner agent-code-review"

# ---------------------------------------------------------------------------
# Canonical project-roadmap URL (raw GitHub content).
# Falls back to the local dashboards/PROJECTS.md if unreachable.
# ---------------------------------------------------------------------------
NODE_PROJECTS_URL=https://raw.githubusercontent.com/Forseti-Life/forseti.life/main/copilot-hq/dashboards/PROJECTS.md

# ---------------------------------------------------------------------------
# Runtime knobs (can be overridden by environment variables)
# ---------------------------------------------------------------------------
# DEV_SYNC_AUTO_PULL=1
# DEV_SYNC_AUTO_COMMIT=0
# DEV_SYNC_AUTO_PUSH=0
# DEV_SYNC_MAX_COMMANDS=1
