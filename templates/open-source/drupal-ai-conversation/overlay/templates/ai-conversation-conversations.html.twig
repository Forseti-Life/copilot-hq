{#
  Generic conversation history list page.
#}

<div class="ai-conversation-conversations">

  <div class="ai-conversation-conversations__header d-flex justify-content-between align-items-center mb-4">
    <h1 class="ai-conversation-conversations__title">{{ 'My Conversations'|t }}</h1>
    <a href="{{ path('ai_conversation.chat_page') }}" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> {{ 'New Conversation'|t }}
    </a>
  </div>

  {% if conversations is empty %}
    <div class="ai-conversation-conversations__empty text-center py-5 text-muted">
      <i class="bi bi-chat-left-dots display-4"></i>
      <h4 class="mt-3">{{ 'No conversations yet'|t }}</h4>
      <p>
        <a href="{{ path('ai_conversation.chat_page') }}" class="btn btn-success mt-2">
          {{ 'Start your first conversation'|t }}
        </a>
      </p>
    </div>
  {% else %}
    <div class="ai-conversation-conversations__list">
      {% for conv in conversations %}
        {% set delete_url = path('ai_conversation.conversation_delete', {'conversation_id': conv.id}) %}
        <div class="card ai-conversation-conversations__item mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div class="ai-conversation-conversations__meta">
                <h5 class="card-title mb-1">{{ conv.title|e }}</h5>
                <p class="text-muted small mb-1">
                  <i class="bi bi-clock"></i>
                  {{ conv.changed|date('M j, Y - H:i') }}
                  &mdash;
                  {{ conv.message_count }} {{ 'messages'|t }}
                </p>
                {% if conv.preview %}
                  <p class="ai-conversation-conversations__preview text-secondary small mb-0">
                    {{ conv.preview|e }}&hellip;
                  </p>
                {% endif %}
              </div>
              <div class="ai-conversation-conversations__actions ms-3 d-flex gap-2 flex-shrink-0">
                <a href="{{ conv.chat_url }}" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-play-fill"></i> {{ 'Resume'|t }}
                </a>
                <a href="{{ conv.export_url }}" class="btn btn-sm btn-outline-secondary">
                  <i class="bi bi-download"></i> {{ 'Download'|t }}
                </a>
                <form method="post" action="{{ delete_url }}" style="display:inline-block;">
                  <button type="submit" class="btn btn-sm btn-outline-danger"
                          onclick="return confirm('{{ 'Delete this conversation?'|t }}')">
                    <i class="bi bi-trash"></i> {{ 'Delete'|t }}
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if has_prev or has_next %}
      <nav aria-label="{{ 'Conversation history pagination'|t }}" class="mt-4">
        <ul class="pagination justify-content-center">
          <li class="page-item {% if not has_prev %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ page - 1 }}"
               {% if not has_prev %}aria-disabled="true" tabindex="-1"{% endif %}>
              <i class="bi bi-chevron-left"></i> {{ 'Previous'|t }}
            </a>
          </li>
          <li class="page-item disabled" aria-current="page">
            <span class="page-link">{{ 'Page'|t }} {{ page }}</span>
          </li>
          <li class="page-item {% if not has_next %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ page + 1 }}"
               {% if not has_next %}aria-disabled="true" tabindex="-1"{% endif %}>
              {{ 'Next'|t }} <i class="bi bi-chevron-right"></i>
            </a>
          </li>
        </ul>
      </nav>
    {% endif %}
  {% endif %}

</div>
